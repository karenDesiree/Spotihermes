rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write for this simple private app
    // Note: In a production app with many users, you should use Firebase Auth
    match /songs/{songId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
