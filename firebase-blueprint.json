{
  "entities": {
    "Song": {
      "title": "Song",
      "description": "A music track with metadata and file URLs",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the song" },
        "artist": { "type": "string", "description": "The artist name" },
        "coverUrl": { "type": "string", "description": "URL to the cover image" },
        "audioUrl": { "type": "string", "description": "URL to the audio file" },
        "lyrics": { "type": "string", "description": "Lyrics of the song" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "ownerId": { "type": "string", "description": "UID of the user who uploaded the song" }
      },
      "required": ["title", "artist", "audioUrl", "createdAt"]
    }
  },
  "firestore": {
    "songs": {
      "schema": "Song",
      "description": "Collection of all songs"
    }
  }
}
