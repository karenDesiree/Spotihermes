{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["username", "role", "email"]
    },
    "Song": {
      "title": "Song",
      "description": "Music track information",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "lyrics": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "artist", "audioUrl", "authorId"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "songs": {
      "schema": "Song",
      "description": "Collection of uploaded songs"
    }
  }
}
